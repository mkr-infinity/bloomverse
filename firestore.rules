rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /citizens/{citizenId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == citizenId;
    }
    match /landmarks/{landmarkId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /dreams/{dreamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /world/{worldId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
// add citizen read permissions
// add citizen write permissions
// add landmark read permissions
// add landmark write permissions
// add dream read permissions
// add dream write permissions
// add world state read
// add world state write
// add chat read permissions
// add chat write permissions
